module Zavudev
  module Models
    module Senders
      module Agent
        type tool_update_params =
          {
            sender_id: String,
            tool_id: String,
            description: String,
            enabled: bool,
            name: String,
            parameters: Zavudev::Senders::Agent::ToolParameters,
            webhook_secret: String?,
            webhook_url: String
          }
          & Zavudev::Internal::Type::request_parameters

        class ToolUpdateParams < Zavudev::Internal::Type::BaseModel
          extend Zavudev::Internal::Type::RequestParameters::Converter
          include Zavudev::Internal::Type::RequestParameters

          attr_accessor sender_id: String

          attr_accessor tool_id: String

          attr_reader description: String?

          def description=: (String) -> String

          attr_reader enabled: bool?

          def enabled=: (bool) -> bool

          attr_reader name: String?

          def name=: (String) -> String

          attr_reader parameters: Zavudev::Senders::Agent::ToolParameters?

          def parameters=: (
            Zavudev::Senders::Agent::ToolParameters
          ) -> Zavudev::Senders::Agent::ToolParameters

          attr_accessor webhook_secret: String?

          attr_reader webhook_url: String?

          def webhook_url=: (String) -> String

          def initialize: (
            sender_id: String,
            tool_id: String,
            ?description: String,
            ?enabled: bool,
            ?name: String,
            ?parameters: Zavudev::Senders::Agent::ToolParameters,
            ?webhook_secret: String?,
            ?webhook_url: String,
            ?request_options: Zavudev::request_opts
          ) -> void

          def to_hash: -> {
            sender_id: String,
            tool_id: String,
            description: String,
            enabled: bool,
            name: String,
            parameters: Zavudev::Senders::Agent::ToolParameters,
            webhook_secret: String?,
            webhook_url: String,
            request_options: Zavudev::RequestOptions
          }
        end
      end
    end
  end
end

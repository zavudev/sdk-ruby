module Zavudev
  module Models
    module Senders
      module Agent
        type tool_create_params =
          {
            sender_id: String,
            description: String,
            name: String,
            parameters: Zavudev::Senders::Agent::ToolParameters,
            webhook_url: String,
            enabled: bool,
            webhook_secret: String
          }
          & Zavudev::Internal::Type::request_parameters

        class ToolCreateParams < Zavudev::Internal::Type::BaseModel
          extend Zavudev::Internal::Type::RequestParameters::Converter
          include Zavudev::Internal::Type::RequestParameters

          attr_accessor sender_id: String

          attr_accessor description: String

          attr_accessor name: String

          attr_accessor parameters: Zavudev::Senders::Agent::ToolParameters

          attr_accessor webhook_url: String

          attr_reader enabled: bool?

          def enabled=: (bool) -> bool

          attr_reader webhook_secret: String?

          def webhook_secret=: (String) -> String

          def initialize: (
            sender_id: String,
            description: String,
            name: String,
            parameters: Zavudev::Senders::Agent::ToolParameters,
            webhook_url: String,
            ?enabled: bool,
            ?webhook_secret: String,
            ?request_options: Zavudev::request_opts
          ) -> void

          def to_hash: -> {
            sender_id: String,
            description: String,
            name: String,
            parameters: Zavudev::Senders::Agent::ToolParameters,
            webhook_url: String,
            enabled: bool,
            webhook_secret: String,
            request_options: Zavudev::RequestOptions
          }
        end
      end
    end
  end
end
